<UserControl x:Class="AIDevSystem.Views.ProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：项目列表 -->
        <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="6" Padding="12" Margin="0,0,8,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📁 项目列表" FontSize="16" FontWeight="Bold" Foreground="#7DF9FF" Margin="0,0,0,12"/>

                <!-- 新建项目 -->
                <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" Margin="0,0,0,4"/>
                        <Button Content="＋ 创建项目" Command="{Binding CreateProjectCommand}"
                                Background="#7C3AED" Foreground="White" BorderThickness="0"
                                Padding="8,6" Cursor="Hand" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Button Grid.Row="2" Content="🔄 刷新" Command="{Binding RefreshCommand}"
                        Background="Transparent" Foreground="#A9BAD7" BorderThickness="0"
                        HorizontalAlignment="Right" Cursor="Hand" Margin="0,0,0,6"/>

                <!-- 项目列表 -->
                <ListBox Grid.Row="3" ItemsSource="{Binding Projects}" 
                         SelectedItem="{Binding SelectedProject}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#E0E0E0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" CornerRadius="4" Margin="0,0,0,2"
                                    Background="Transparent">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" 
                                               Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                                CornerRadius="4" Padding="2" Margin="0,0,0,1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#3B3B5C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" Background="#444" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

        <!-- 右侧：任务区 -->
        <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 需求输入 -->
                <Border Background="#1E1E2E" CornerRadius="4" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding RequirementText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 AcceptsReturn="True" MinHeight="60" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                            <Button Content="💬 与PM讨论" Command="{Binding DiscussCommand}"
                                    Background="Transparent" Foreground="#7DF9FF"
                                    BorderBrush="#7DF9FF" BorderThickness="1"
                                    Padding="12,8" Cursor="Hand" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Button Content="🧠 拆解" Command="{Binding DecomposeCommand}"
                                    Background="#7C3AED" Foreground="White" BorderThickness="0"
                                    Padding="12,8" Cursor="Hand" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Button Content="▶ 执行全部" Command="{Binding ExecuteAllCommand}"
                                    Background="#059669" Foreground="White" BorderThickness="0"
                                    Padding="12,8" Cursor="Hand" FontWeight="Bold" Margin="0,0,0,4"/>
                            <CheckBox Content="PM审查" IsChecked="{Binding EnablePMReview}"
                                      Foreground="#E0E0E0" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 进度 -->
                <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                        Visibility="{Binding Progress.IsActive, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding Progress.StatusText, Mode=OneWay}" Foreground="#7DF9FF" FontSize="12"/>
                        <ProgressBar Value="{Binding Progress.OverallPercentage, Mode=OneWay}" Minimum="0" Maximum="100"
                                     Height="4" Margin="0,4,0,0" Foreground="#7DF9FF" Background="#1E1E2E"/>
                    </StackPanel>
                </Border>

                <!-- 任务列表 -->
                <ListBox Grid.Row="2" ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" CornerRadius="4" Margin="0,0,0,3"
                                    Background="#1E1E2E">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Status, StringFormat='[{0}] '}" 
                                                       Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="11" 
                                                   Foreground="#999" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="400"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Difficulty}" FontSize="11" Foreground="#7DF9FF"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <Button Content="▶" Command="{Binding DataContext.ExecuteTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Background="#059669" Foreground="White" BorderThickness="0"
                                                Width="30" Height="30" Cursor="Hand" Margin="0,0,4,0"/>
                                        <Button Content="📋" Command="{Binding DataContext.ViewTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"
                                                Background="#3B3B5C" Foreground="White" BorderThickness="0"
                                                Width="30" Height="30" Cursor="Hand"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
