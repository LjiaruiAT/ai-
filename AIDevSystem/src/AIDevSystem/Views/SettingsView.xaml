<UserControl x:Class="AIDevSystem.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="700">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Background="#2A2A3E" CornerRadius="6" Padding="24" MaxWidth="600">
            <StackPanel>
                <TextBlock Text="⚙ 系统设置" FontSize="20" FontWeight="Bold" Foreground="#7DF9FF" Margin="0,0,0,24"/>

                <!-- API Key -->
                <TextBlock Text="DeepSeek API Key" FontSize="13" Foreground="#A9BAD7" Margin="0,0,0,4"/>
                <TextBox Text="{Binding ApiKey}" Foreground="#E0E0E0" CaretBrush="#E0E0E0"
                         Background="#1E1E2E" BorderBrush="#444" BorderThickness="1"
                         Padding="8,6" Margin="0,0,0,16"
                         Style="{StaticResource DarkTextBox}"/>

                <!-- 默认PM模型 -->
                <TextBlock Text="默认项目经理模型" FontSize="13" Foreground="#A9BAD7" Margin="0,0,0,4"/>
                <ComboBox Text="{Binding DefaultPmModel}" Foreground="#E0E0E0"
                          Background="#1E1E2E" BorderBrush="#444"
                          Padding="8,6" Margin="0,0,0,16">
                    <ComboBoxItem Content="claude"/>
                    <ComboBoxItem Content="reasonix"/>
                    <ComboBoxItem Content="deepseek"/>
                </ComboBox>

                <!-- 自动模式 -->
                <CheckBox Content="自动执行模式（拆解后自动运行所有子任务）" 
                          IsChecked="{Binding AutoMode}"
                          Foreground="#E0E0E0" Margin="0,0,0,16"/>

                <!-- 项目根目录 -->
                <TextBlock Text="项目根目录" FontSize="13" Foreground="#A9BAD7" Margin="0,0,0,4"/>
                <TextBox Text="{Binding ProjectRoot}" Foreground="#E0E0E0" CaretBrush="#E0E0E0"
                         Background="#1E1E2E" BorderBrush="#444" BorderThickness="1"
                         Padding="8,6" Margin="0,0,0,24"
                         Style="{StaticResource DarkTextBox}"/>

                <!-- 保存 -->
                <Button Content="💾 保存设置" Command="{Binding SaveCommand}"
                        Background="#7C3AED" Foreground="White" BorderThickness="0"
                        Padding="16,10" FontWeight="Bold" FontSize="14"
                        Cursor="Hand" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
