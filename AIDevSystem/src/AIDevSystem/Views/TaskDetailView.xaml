<UserControl x:Class="AIDevSystem.Views.TaskDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 返回按钮 + 任务标题 -->
        <Border Background="#2A2A3E" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Button Content="← 返回项目列表" Command="{Binding GoBackCommand}"
                        Background="Transparent" Foreground="#7DF9FF"
                        BorderBrush="#7DF9FF" BorderThickness="1"
                        Padding="10,4" Cursor="Hand" HorizontalAlignment="Left"
                        Margin="0,0,0,8"/>
                <StackPanel Grid.Row="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋 " FontSize="18"/>
                        <TextBlock Text="{Binding Task.Title}" FontSize="18" FontWeight="Bold" Foreground="#7DF9FF"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Task.Description}" FontSize="13" Foreground="#A9BAD7" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="状态: " Foreground="#888"/>
                        <TextBlock Text="{Binding Task.Status}" Foreground="#FBBF24" FontWeight="SemiBold"/>
                        <TextBlock Text="  难度: " Foreground="#888" Margin="16,0,0,0"/>
                        <TextBlock Text="{Binding Task.Difficulty}" Foreground="#7DF9FF"/>
                        <TextBlock Text="  模型: " Foreground="#888" Margin="16,0,0,0"/>
                        <TextBlock Text="{Binding Task.ModelSelected}" Foreground="#E0E0E0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 执行记录列表 -->
        <TextBlock Grid.Row="1" Text="执行记录" FontSize="14" FontWeight="Bold"
                   Foreground="#A9BAD7" Margin="0,0,0,6"/>

        <ListBox Grid.Row="2" ItemsSource="{Binding Executions}" SelectedItem="{Binding SelectedExecution}"
                 Background="Transparent" BorderThickness="0" MaxHeight="120">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" CornerRadius="4" Margin="0,0,0,2" Background="#1E1E2E">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Success, Converter={StaticResource SuccessToEmojiConverter}}"
                                       Foreground="{Binding Success, Converter={StaticResource BoolToColorConverter}}"
                                       FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Model}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding ExecutedAt}" Foreground="#888" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 输出内容 -->
        <Border Grid.Row="3" Background="#1E1E2E" CornerRadius="6" Padding="12" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="输出内容" FontSize="13" Foreground="#A9BAD7" Margin="0,0,0,6"/>
                <TextBox Grid.Row="1" Text="{Binding OutputText}"
                         Foreground="#E0E0E0" Background="#0D0D1A"
                         IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         BorderBrush="#333" BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
