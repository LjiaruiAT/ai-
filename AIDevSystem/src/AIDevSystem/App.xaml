<Application x:Class="AIDevSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:AIDevSystem.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 转换器 -->
            <conv:InvertBoolConverter x:Key="InvertBoolConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
            <conv:ZeroToVisibilityConverter x:Key="ZeroToVisConverter"/>
            <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <conv:SuccessToEmojiConverter x:Key="SuccessToEmojiConverter"/>
            <!-- Phase 1: 新增转换器 -->
            <conv:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <conv:RoleToAlignmentConverter x:Key="RoleToAlignmentConverter"/>
            <conv:RoleToVisibilityConverter x:Key="RoleToUserVisConverter" Role="user"/>
            <conv:RoleToVisibilityConverter x:Key="RoleToPmVisConverter" Role="pm"/>
            <conv:RoleToVisibilityConverter x:Key="RoleToSystemVisConverter" Role="system"/>

            <!-- 全局背景 -->
            <Style TargetType="Window">
                <Setter Property="Background" Value="#1E1E2E"/>
            </Style>
            <Style TargetType="UserControl">
                <Setter Property="Background" Value="#1E1E2E"/>
                <Setter Property="Foreground" Value="#E0E0E0"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
