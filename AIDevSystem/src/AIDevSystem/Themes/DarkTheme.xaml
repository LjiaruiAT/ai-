<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 卡片 ===== -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="#2A2A3E"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BorderBrush" Value="#3B3B5C"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ===== 按钮变体 ===== -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#7C3AED"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#6D28D9"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="#059669"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#047857"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="#DC2626"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#B91C1C"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#7DF9FF"/>
        <Setter Property="BorderBrush" Value="#7DF9FF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1A2A3E"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== ProgressBar ===== -->
    <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6"/>
        <Setter Property="Background" Value="#1E1E2E"/>
        <Setter Property="Foreground" Value="#7DF9FF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                        <Border Name="PART_Track" Background="Transparent" CornerRadius="3"/>
                        <Border Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                CornerRadius="3" HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 聊天气泡 ===== -->
    <Style x:Key="ChatBubbleUserStyle" TargetType="Border">
        <Setter Property="Background" Value="#7C3AED"/>
        <Setter Property="CornerRadius" Value="12,12,4,12"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="MaxWidth" Value="420"/>
        <Setter Property="Margin" Value="60,2,8,2"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style x:Key="ChatBubblePmStyle" TargetType="Border">
        <Setter Property="Background" Value="#2A2A3E"/>
        <Setter Property="CornerRadius" Value="12,12,12,4"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="MaxWidth" Value="420"/>
        <Setter Property="Margin" Value="8,2,60,2"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="BorderBrush" Value="#3B3B5C"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ===== ActivityIndicator 动画 ===== -->
    <Style x:Key="ActivityDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="10"/>
        <Setter Property="Height" Value="10"/>
        <Setter Property="Fill" Value="#7DF9FF"/>
    </Style>

    <!-- ===== 导航按钮 ===== -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#A9BAD7"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}" CornerRadius="4">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2A2A3E"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== 文本框 ===== -->
    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#1E1E2E"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="BorderBrush" Value="#444"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CaretBrush" Value="#E0E0E0"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <!-- ===== CheckBox ===== -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <!-- ===== ComboBox ===== -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#1E1E2E"/>
        <Setter Property="BorderBrush" Value="#444"/>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="#1E1E2E"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <!-- ===== DataGrid ===== -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#2A2A3E"/>
        <Setter Property="Foreground" Value="#7DF9FF"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="BorderBrush" Value="#333"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="#E0E0E0"/>
        <Setter Property="BorderBrush" Value="#2A2A3E"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="#1E1E2E"/>
    </Style>
</ResourceDictionary>
