<UserControl x:Class="AIDevSystem.Controls.ActivityIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="Dot" Width="10" Height="10" Fill="#7DF9FF"
                     VerticalAlignment="Center" Margin="0,0,6,0">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.3" To="1.0" Duration="0:0:0.8"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <TextBlock x:Name="StatusLabel" Text="处理中..."
                       Foreground="#A9BAD7" FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
