<Window x:Class="AIDevSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AIDevSystem.Views"
        xmlns:vm="clr-namespace:AIDevSystem.ViewModels"
        Title="AI Dev System" Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- ViewModel → View 映射 -->
        <DataTemplate DataType="{x:Type vm:ProjectListViewModel}">
            <views:ProjectView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TaskDetailViewModel}">
            <views:TaskDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChatViewModel}">
            <views:ChatView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HelpViewModel}">
            <views:HelpView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <Border Grid.Column="0" Grid.Row="0" Background="#1E1E2E" BorderBrush="#333" BorderThickness="0,0,1,0">
            <StackPanel Margin="12,20,12,0">
                <TextBlock Text="AI Dev System" FontSize="18" FontWeight="Bold"
                           Foreground="#7DF9FF" Margin="0,0,0,30" />

                <Button Content="📁 项目" Style="{StaticResource NavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="projects"
                        Margin="0,0,0,8" />
                <Button Content="⚙ 设置" Style="{StaticResource NavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="settings"
                        Margin="0,0,0,8" />
                <Button Content="📊 仪表盘" Style="{StaticResource NavButton}"
                        Command="{Binding NavigateCommand}" CommandParameter="dashboard"
                        Margin="0,0,0,8" />
                <Button Content="❓ 帮助" Style="{StaticResource NavButton}"
                        Command="{Binding HelpCommand}"
                        Margin="0,0,0,8" />
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <ContentControl Grid.Column="1" Grid.Row="0" Content="{Binding CurrentView}" Margin="10" />

        <!-- 底部状态栏 -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2" Background="#2A2A3E">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Margin="8,4">
                <TextBlock Text="{Binding StatusText}" Foreground="#A9BAD7" FontSize="12" VerticalAlignment="Center"/>
                <Separator Style="{x:Null}" Margin="12,0" Visibility="Collapsed"/>
                <TextBlock Text="{Binding TaskProgressText}" Foreground="#7DF9FF" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>
            <!-- 进度条 -->
            <ProgressBar Grid.Column="1" Style="{StaticResource ProgressBarStyle}"
                         Value="{Binding OverallProgress}" Minimum="0" Maximum="100"
                         Visibility="{Binding ShowProgressBar, Converter={StaticResource BoolToVisConverter}}"
                         Width="200" Height="4" HorizontalAlignment="Right" Margin="0,0,12,0"/>
        </Grid>
    </Grid>
</Window>
